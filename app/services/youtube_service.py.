# app/services/youtube_service.py
from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import Flow
from googleapiclient.discovery import build
from googleapiclient.http import MediaFileUpload
import os

class YouTubeService:
    def __init__(self, access_token, refresh_token=None):
        """YouTube API 초기화"""
        self.access_token = access_token
        self.refresh_token = refresh_token
        self.youtube = None
        self._initialize_youtube()
    
    def _initialize_youtube(self):
        """YouTube API 클라이언트 초기화"""
        credentials = Credentials(
            token=self.access_token,
            refresh_token=self.refresh_token,
            token_uri='https://oauth2.googleapis.com/token',
            client_id=os.getenv('GOOGLE_CLIENT_ID'),
            client_secret=os.getenv('GOOGLE_CLIENT_SECRET')
        )
        self.youtube = build('youtube', 'v3', credentials=credentials)
    
    def upload_short(self, file_path, title, description=''):
        """YouTube Shorts 업로드"""
        try:
            request_body = {
                'snippet': {
                    'title': title,
                    'description': description,
                    'tags': ['shorts'],
                    'categoryId': '22'
                },
                'status': {
                    'privacyStatus': 'public'
                }
            }
            
            media = MediaFileUpload(file_path, mimetype='video/mp4', resumable=True)
            request = self.youtube.videos().insert(
                part='snippet,status',
                body=request_body,
                media_body=media
            )
            
            response = request.execute()
            return {'status': 'success', 'video_id': response['id']}
        except Exception as e:
            return {'status': 'error', 'message': str(e)}
    
    def upload_longform(self, file_path, title, description=''):
        """YouTube 긴형식 동영상 업로드"""
        try:
            request_body = {
                'snippet': {
                    'title': title,
                    'description': description,
                    'categoryId': '22'
                },
                'status': {
                    'privacyStatus': 'public'
                }
            }
            
            media = MediaFileUpload(file_path, mimetype='video/mp4', resumable=True)
            request = self.youtube.videos().insert(
                part='snippet,status',
                body=request_body,
                media_body=media
            )
            
            response = request.execute()
            return {'status': 'success', 'video_id': response['id']}
        except Exception as e:
            return {'status': 'error', 'message': str(e)}
    
    def get_channel_info(self):
        """채널 정보 조회"""
        try:
            request = self.youtube.channels().list(part='snippet', mine=True)
            response = request.execute()
            if response.get('items'):
                return {'status': 'success', 'channel': response['items'][0]}
            return {'status': 'error', 'message': '채널을 찾을 수 없습니다'}
        except Exception as e:
            return {'status': 'error', 'message': str(e)}
